---
import CartDrawerToggle from '@components/cart/CartDrawerToggle.astro';
import Central from '@layouts/elements/arrangement/Central.astro';
import HeaderBackButton from '@components/HeaderBackButton.astro';
import HeaderTitle from '@components/HeaderTitle.astro';

interface Props {
    showBackButton?: boolean;
}

const { showBackButton = false } = Astro.props;
---

<div class="flex gap-px bg-green">
    {showBackButton && <HeaderBackButton />}
    <div class={`grow h-12 sm:h-14 lg:h-20 xl:h-24 bg-white ${showBackButton === false && 'pl-12 sm:pl-14 lg:pl-0'}`}>
        <div class="block h-full">
            <Central>
                <HeaderTitle />
            </Central>
        </div>
    </div>
    <div class="h-12 w-12 bg-white sm:h-14 sm:w-14 lg:h-20 lg:w-20 xl:h-24 xl:w-24">
        <Central>
            <div class="p-2">
                <CartDrawerToggle />
            </div>
        </Central>
    </div>
</div>
<div class="flex-1 border-t border-green text-center lg:hidden">
    <HeaderTitle />
</div>
